{
    "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentParameters.json#",
    "contentVersion": "1.0.0.0",
    "parameters": {
      "name": {
        "value": "${AZURE_ENV_NAME}"
      },
      "location": {
        "value": "${AZURE_LOCATION}"
      },
      "principalId": {
        "value": "${AZURE_PRINCIPAL_ID}"
      },
      "serverExists": {
        "value": "${SERVICE_SERVER_RESOURCE_EXISTS=false}"
      },
      "entraAdminGroupId": {
        "value": "${ENTRA_ADMIN_GROUP_ID}"
      },
      "entraDevClientId": {
        "value": "${ENTRA_DEV_CLIENT_ID}"
      },
      "entraDevClientSecret": {
        "value": "${ENTRA_DEV_CLIENT_SECRET}"
      },
      "entraProdClientId": {
        "value": "${ENTRA_PROD_CLIENT_ID}"
      }
    }
  }
