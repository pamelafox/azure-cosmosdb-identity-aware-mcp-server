# Azure Cosmos DB Configuration
AZURE_COSMOSDB_ACCOUNT=your-cosmosdb-account
AZURE_COSMOSDB_DATABASE=expenses-database
AZURE_COSMOSDB_USER_CONTAINER=user-expenses

# Azure/Entra ID OAuth Configuration
AZURE_TENANT_ID=your-tenant-id
ENTRA_PROXY_AZURE_CLIENT_ID=your-client-id
ENTRA_PROXY_AZURE_CLIENT_SECRET=your-client-secret

# OpenTelemetry Configuration
OPENTELEMETRY_PLATFORM=appinsights
# APPLICATIONINSIGHTS_CONNECTION_STRING=your-connection-string
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
